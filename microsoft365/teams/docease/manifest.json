{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.13/MicrosoftTeams.schema.json",
  "manifestVersion": "1.13",
  "version": "1.0.0",
  "id": "1fec8b89-c409-471b-bd7e-d7d36d960cc3",
  "packageName": "com.fometaux.docease",
  "developer": {
    "name": "FO Métaux",
    "websiteUrl": "https://fom-docease.vercel.app",
    "privacyUrl": "https://fom-docease.vercel.app/privacy",
    "termsOfUseUrl": "https://fom-docease.vercel.app/terms"
  },
  "name": {
    "short": "DocEase",
    "full": "DocEase - Générateur de Documents FO Métaux"
  },
  "description": {
    "short": "Génération de documents syndicaux FO Métaux",
    "full": "Générateur de documents FO Métaux — Convocations, Désignations, Circulaires et plus. Créez et gérez vos documents syndicaux directement depuis Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#aa4584",
  "staticTabs": [
    {
      "entityId": "docease-home",
      "name": "DocEase",
      "contentUrl": "https://fom-docease.vercel.app",
      "websiteUrl": "https://fom-docease.vercel.app",
      "scopes": ["personal"]
    },
    {
      "entityId": "docease-convocation",
      "name": "Convocation",
      "contentUrl": "https://fom-docease.vercel.app/?type=convocation",
      "websiteUrl": "https://fom-docease.vercel.app/?type=convocation",
      "scopes": ["personal"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://fom-docease.vercel.app",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupchat"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "fom-docease.vercel.app",
    "*.vercel.app"
  ]
}
