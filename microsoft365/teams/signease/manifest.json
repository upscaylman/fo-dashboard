{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.13/MicrosoftTeams.schema.json",
  "manifestVersion": "1.13",
  "version": "1.0.0",
  "id": "7003a193-a7f8-4bc4-b44d-f3d79f3d5f89",
  "packageName": "com.fometaux.signease",
  "developer": {
    "name": "FO Métaux",
    "websiteUrl": "https://fom-signease.vercel.app",
    "privacyUrl": "https://fom-signease.vercel.app/privacy",
    "termsOfUseUrl": "https://fom-signease.vercel.app/terms"
  },
  "name": {
    "short": "SignEase",
    "full": "SignEase - Signature Électronique FO Métaux"
  },
  "description": {
    "short": "Signature électronique sécurisée pour documents syndicaux",
    "full": "Solution professionnelle de signature électronique sécurisée pour vos documents syndicaux FO Métaux. Signez, envoyez et suivez vos documents directement depuis Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#B71C1C",
  "staticTabs": [
    {
      "entityId": "signease-home",
      "name": "SignEase",
      "contentUrl": "https://fom-signease.vercel.app",
      "websiteUrl": "https://fom-signease.vercel.app",
      "scopes": ["personal"]
    },
    {
      "entityId": "signease-inbox",
      "name": "Mes Documents",
      "contentUrl": "https://fom-signease.vercel.app/#/inbox",
      "websiteUrl": "https://fom-signease.vercel.app/#/inbox",
      "scopes": ["personal"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://fom-signease.vercel.app",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupchat"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "fom-signease.vercel.app",
    "*.vercel.app"
  ]
}
