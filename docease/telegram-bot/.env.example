# ======================================================
# DocEase Telegram Bot - Configuration
# Copiez ce fichier en .env et remplissez les valeurs
# ======================================================

# Token du bot Telegram (obtenu via @BotFather sur Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# IDs Telegram des utilisateurs autorisés (séparés par des virgules)
# Laissez vide pour autoriser tout le monde (DANGEREUX)
# Pour obtenir votre ID: envoyez /start à @userinfobot sur Telegram
ALLOWED_TELEGRAM_IDS=123456789,987654321
